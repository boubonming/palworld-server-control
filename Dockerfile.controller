FROM python:3.12-slim-trixie

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    QT_QPA_PLATFORM=offscreen \
    PALWORLD_CONTROL_DATA_DIR=/data

WORKDIR /app
COPY requirements.txt .
RUN apt-get update \
    && apt-get install --no-install-recommends -y libglib2.0-0t64 \
    && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir -r requirements.txt
COPY src ./src

RUN mkdir -p /data

VOLUME ["/data"]
EXPOSE 8080
CMD ["python", "src/server_main.py", "--host", "0.0.0.0", "--port", "8080"]
